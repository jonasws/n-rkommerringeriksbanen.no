---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Når kommer Ringeriksbanen?",
  description = "Nedtelling til byggestart av Ringeriksbanen",
} = Astro.props;
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-dracula-bg text-dracula-fg min-h-screen font-sans antialiased">
    <slot />
  </body>
</html>
